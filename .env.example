# STRATA site â€” Stripe configuration
# Copy to .env.local and fill in. Without these the site still runs;
# checkout shows a quiet "not yet open" note instead of a payment form.

STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Recurring prices (subscription mode), one per tier and per cycle.
# Tier ids must match src/license.rs claims: personal | professional | studio.
# These are the FOUNDING (launch) prices and MUST match lib/tiers.ts exactly:
#   personal      $5/mo  · $39/yr
#   professional  $9/mo  · $79/yr
#   studio        $24/mo · $199/yr
# The yearly saving is derived from these amounts (not a fixed "two months").
# When the founding rate ends, raise the Stripe prices AND lib/tiers.ts
# together; tiers.ts `regularMonthly` is only the struck-through anchor.
STRIPE_PRICE_PERSONAL=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_STUDIO=price_...
STRIPE_PRICE_PERSONAL_ANNUAL=price_...
STRIPE_PRICE_PROFESSIONAL_ANNUAL=price_...
STRIPE_PRICE_STUDIO_ANNUAL=price_...

# Stripe trial days before the first charge (0 or empty = no trial).
# Read by both the pages (display) and the checkout session (enforcement).
NEXT_PUBLIC_TRIAL_DAYS=14

# When the 50%-off founding offer ends — the date the countdown ticks to.
# ISO 8601 with an explicit offset (UAE = +04:00). MUST be a date you honour:
# on it, raise the Stripe prices to the regular rate AND set lib/tiers.ts
# priceMonthly = regularMonthly in the same commit. The countdown hides itself
# once it passes. Leave empty to remove the countdown. Default: 2026-07-13.
NEXT_PUBLIC_FOUNDING_DEADLINE=2026-07-13T23:59:59+04:00

# Canonical URL for metadata / return URLs (defaults to http://localhost:3010 in dev).
NEXT_PUBLIC_SITE_URL=http://localhost:3010

# Where the bilingual field guide (docs-site/site) is published. Locally a
# junction public/docs -> ../docs-site/site serves it; in production upload
# that tree to /docs on the same host (or set an absolute URL here).
NEXT_PUBLIC_DOCS_URL=/docs

# The shipped Windows bundle (dist.ps1 output, zipped, on your CDN/host).
# Until set, /download shows a quiet "build being prepared" note.
NEXT_PUBLIC_DOWNLOAD_URL_WIN=

# Stripe customer-portal login link (Dashboard -> Settings -> Billing ->
# Customer portal -> no-code link). Until set, /account routes changes
# through the maker's email.
NEXT_PUBLIC_STRIPE_PORTAL_URL=

